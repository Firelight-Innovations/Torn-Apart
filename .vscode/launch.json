{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Fire Editor (Extension Host)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "${workspaceFolder}",
        "--extensionDevelopmentPath=${workspaceFolder}/editor/extension"
      ],
      "outFiles": ["${workspaceFolder}/editor/extension/dist/**/*.js"],
      "preLaunchTask": "fire-editor: build"
    }
  ]
}
