{
  "name": "fire-editor",
  "displayName": "Fire Editor",
  "description": "Unity-Editor-style visual editor for the Torn Apart (Fire) engine, running inside VS Code / Cursor.",
  "version": "0.1.0",
  "publisher": "firelight",
  "private": true,
  "license": "SEE LICENSE IN ../../LICENSE",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18"
  },
  "categories": ["Other"],
  "main": "./dist/extension.js",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "commands": [
      {
        "command": "fireEditor.restartDaemon",
        "title": "Fire Editor: Restart Daemon",
        "category": "Fire Editor"
      },
      {
        "command": "fireEditor.showLog",
        "title": "Fire Editor: Show Daemon Log",
        "category": "Fire Editor"
      },
      {
        "command": "fireEditor.showStatus",
        "title": "Fire Editor: Show Status",
        "category": "Fire Editor"
      },
      {
        "command": "fireEditor.openSceneView",
        "title": "Fire Editor: Open Scene View",
        "category": "Fire Editor"
      },
      {
        "command": "fireEditor.openWorldSeed",
        "title": "Fire Editor: Open World by Seed",
        "category": "Fire Editor"
      },
      {
        "command": "fireEditor.openWorldSave",
        "title": "Fire Editor: Open World from Save",
        "category": "Fire Editor"
      },
      {
        "command": "fireEditor.saveScene",
        "title": "Fire Editor: Save Scene",
        "category": "Fire Editor",
        "icon": "$(save)"
      },
      {
        "command": "fireEditor.saveSceneAs",
        "title": "Fire Editor: Save Scene As…",
        "category": "Fire Editor"
      },
      {
        "command": "fireEditor.refreshHierarchy",
        "title": "Refresh",
        "category": "Fire Editor",
        "icon": "$(refresh)"
      },
      {
        "command": "fireEditor.createEmpty",
        "title": "Create Empty",
        "category": "Fire Editor",
        "icon": "$(add)"
      },
      {
        "command": "fireEditor.createCube",
        "title": "Create Cube",
        "category": "Fire Editor"
      },
      {
        "command": "fireEditor.createSphere",
        "title": "Create Sphere",
        "category": "Fire Editor"
      },
      {
        "command": "fireEditor.createLight",
        "title": "Create Light",
        "category": "Fire Editor"
      },
      {
        "command": "fireEditor.createSpawn",
        "title": "Create Spawn Point",
        "category": "Fire Editor"
      },
      {
        "command": "fireEditor.renameObject",
        "title": "Rename",
        "category": "Fire Editor",
        "icon": "$(edit)"
      },
      {
        "command": "fireEditor.deleteObject",
        "title": "Delete",
        "category": "Fire Editor",
        "icon": "$(trash)"
      },
      {
        "command": "fireEditor.frameObject",
        "title": "Frame in Scene View",
        "category": "Fire Editor",
        "icon": "$(eye)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "fireEditor",
          "title": "Fire Editor",
          "icon": "media/flame.svg"
        }
      ]
    },
    "views": {
      "fireEditor": [
        {
          "id": "fireEditor.hierarchy",
          "name": "Hierarchy",
          "icon": "media/flame.svg",
          "contextualTitle": "Fire Editor Hierarchy"
        },
        {
          "id": "fireEditor.inspector",
          "type": "webview",
          "name": "Inspector",
          "icon": "media/flame.svg",
          "contextualTitle": "Fire Editor Inspector"
        }
      ]
    },
    "keybindings": [
      {
        "command": "fireEditor.saveScene",
        "key": "ctrl+s",
        "mac": "cmd+s",
        "when": "activeWebviewPanelId == 'fireEditor.sceneView'"
      },
      {
        "command": "fireEditor.saveScene",
        "key": "ctrl+s",
        "mac": "cmd+s",
        "when": "focusedView == 'fireEditor.hierarchy'"
      }
    ],
    "submenus": [
      {
        "id": "fireEditor.createMenu",
        "label": "Create Object",
        "icon": "$(add)"
      }
    ],
    "menus": {
      "fireEditor.createMenu": [
        { "command": "fireEditor.createEmpty", "group": "1_create@1" },
        { "command": "fireEditor.createCube", "group": "1_create@2" },
        { "command": "fireEditor.createSphere", "group": "1_create@3" },
        { "command": "fireEditor.createLight", "group": "1_create@4" },
        { "command": "fireEditor.createSpawn", "group": "1_create@5" }
      ],
      "view/title": [
        { "submenu": "fireEditor.createMenu", "when": "view == fireEditor.hierarchy", "group": "navigation@1" },
        { "command": "fireEditor.refreshHierarchy", "when": "view == fireEditor.hierarchy", "group": "navigation@2" }
      ],
      "view/item/context": [
        { "command": "fireEditor.frameObject", "when": "view == fireEditor.hierarchy && viewItem == sceneObject", "group": "inline@1" },
        { "submenu": "fireEditor.createMenu", "when": "view == fireEditor.hierarchy && viewItem == sceneObject", "group": "1_create" },
        { "command": "fireEditor.renameObject", "when": "view == fireEditor.hierarchy && viewItem == sceneObject", "group": "2_edit@1" },
        { "command": "fireEditor.deleteObject", "when": "view == fireEditor.hierarchy && viewItem == sceneObject", "group": "2_edit@2" }
      ]
    },
    "configuration": {
      "title": "Fire Editor",
      "properties": {
        "fireEditor.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Python interpreter for the daemon. Empty = autodetect the repo .venv."
        },
        "fireEditor.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Spawn the Fire Editor daemon automatically when a Torn Apart workspace opens."
        },
        "fireEditor.autoOpenSceneView": {
          "type": "boolean",
          "default": true,
          "description": "Open the 3D Scene View automatically once the daemon connects. Disable to start the daemon headless and open the view manually."
        },
        "fireEditor.logLevel": {
          "type": "string",
          "enum": ["debug", "info", "warning", "error"],
          "default": "info",
          "description": "Daemon log verbosity."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "check": "tsc --noEmit -p ./ && tsc -p tsconfig.webview.json",
    "build:tests": "node esbuild.js --tests",
    "test": "node esbuild.js --tests && node --test \"dist/test/**/*.test.js\"",
    "vscode:prepublish": "npm run check && node esbuild.js --production"
  },
  "dependencies": {
    "three": "^0.165.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/three": "^0.165.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.21.5",
    "typescript": "^5.4.0"
  }
}
